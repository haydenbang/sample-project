# ShopAdmin 백엔드 환경 변수 예시
# 새 환경 변수를 추가하면 Dockerfile, docker-compose.yml, CI 워크플로에도 반영해야 한다.

APP_NAME=ShopAdmin API
ENVIRONMENT=development
DEBUG=true

# 데이터베이스 (개발: SQLite / 운영: postgresql://user:pass@host:5432/shopadmin)
DATABASE_URL=sqlite:///./shopadmin.db

# 보안
SECRET_KEY=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (콤마 구분)
CORS_ORIGINS=http://localhost:5173
